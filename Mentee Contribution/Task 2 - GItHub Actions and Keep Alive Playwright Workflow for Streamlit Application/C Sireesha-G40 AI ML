name: Keep Streamlit App Alive

on:
schedule:
- cron: "0 */6 * * *"
workflow_dispatch:

jobs:
keep-alive:
runs-on: ubuntu-latest

```
steps:
  - uses: actions/checkout@v4

  - uses: actions/setup-node@v4
    with:
      node-version: 20

  - run: npm install playwright

  - run: node keep_alive.js
```
